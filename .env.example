# Copy to `.env` at the **repository root** (same folder as package.json).
# Vite (web) only reads variables prefixed with VITE_.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Do not put CLAUDE_API_KEY here — set it in Supabase Dashboard → Edge Functions → Secrets,
# or: supabase secrets set CLAUDE_API_KEY=...
