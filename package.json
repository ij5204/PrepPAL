{
  "name": "preppal",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @preppal/web",
    "dev:web": "npm run dev -w @preppal/web",
    "mobile": "npm run start -w @preppal/mobile",
    "dev:mobile": "npm run start -w @preppal/mobile",
    "web": "npm run dev -w @preppal/web",
    "admin": "npm run dev -w @preppal/admin",
    "build": "npm run build:web && npm run build:admin",
    "build:web": "npm run build -w @preppal/web",
    "build:admin": "npm run build -w @preppal/admin",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "supabase:start": "supabase start",
    "supabase:migrate": "supabase db push",
    "supabase:reset": "supabase db reset"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
