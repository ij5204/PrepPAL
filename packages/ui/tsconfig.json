{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@preppal/types": ["../types/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts"]
}
